# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=crm_dev
DATABASE_USER=crm
DATABASE_PASSWORD=localdev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenSearch
OPENSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET=change-me-in-production-use-a-64-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# S3 (LocalStack for local dev)
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=crm-assets
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Email (Mailpit for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@crm.local

# CORS (comma-separated origins for production, omit for allow-all in dev)
# CORS_ORIGIN=https://your-web-app.up.railway.app

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development
PORT=3001
